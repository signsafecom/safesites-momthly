# =============================================
# SafeSite Environment Configuration
# =============================================
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to source control.

# ---- Application ----
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000
API_BASE_URL=http://localhost:4000

# ---- Security ----
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
ENCRYPTION_KEY=32-byte-hex-string

# ---- Database (PostgreSQL) ----
DATABASE_URL=postgresql://safesites:password@localhost:5432/safesites

# ---- AWS ----
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_BUCKET=your-s3-bucket-name
AWS_CLOUDFRONT_DOMAIN=your-cloudfront-domain.cloudfront.net

# ---- Google Cloud Vision (OCR) ----
GOOGLE_CLOUD_PROJECT_ID=your-google-cloud-project-id
GOOGLE_CLOUD_KEY_FILE=./google-credentials.json

# ---- OpenAI ----
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4-turbo-preview

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
STRIPE_PRICE_ID_MONTHLY=price_your-monthly-price-id

# ---- Email (SMTP) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@safesites.com

# ---- NotarizeMe API ----
NOTARIZEME_API_KEY=your-notarizeme-api-key
NOTARIZEME_API_URL=https://api.notarizeme.com/v1

# ---- Redis (session/cache) ----
REDIS_URL=redis://localhost:6379

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ---- Logging ----
LOG_LEVEL=info
